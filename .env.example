# image-router configuration
# Copy this file to .env and fill in your values

# Upstream API endpoint (the model API to forward requests to)
CODEX_PLUS_URL=https://api.deepseek.com

# VL model API key (e.g., Dashscope/qwen-vl-plus)
VL_API_KEY=your_vl_api_key_here
VL_MODEL=qwen-vl-plus
VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# Enable VL image analysis (true/false)
VL_ENABLED=true

# Proxy listen port
PROXY_PORT=23456
